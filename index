<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FACTORY RUN — El Juego de la Producción</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&family=Barlow+Condensed:wght@700;900&display=swap');

:root {
  --orange:   #FF6B1A;
  --yellow:   #FFD400;
  --cream:    #FFF5E0;
  --dark:     #1A1208;
  --brown:    #3D2A08;
  --steel:    #8FA3B1;
  --green:    #3DBA5C;
  --red:      #E03030;
  --blue:     #2F80ED;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--dark);
  font-family: 'Barlow', sans-serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  overflow-x: hidden;
  padding-bottom: 40px;
}

/* ─── HEADER ─── */
header {
  width: 100%;
  background: var(--brown);
  border-bottom: 4px solid var(--orange);
  padding: 16px 0 12px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    90deg,
    transparent 0px, transparent 28px,
    rgba(255,255,255,0.03) 28px, rgba(255,255,255,0.03) 30px
  );
}

.header-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: 6px;
  color: var(--orange);
  text-transform: uppercase;
  margin-bottom: 4px;
}

.header-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(38px, 8vw, 64px);
  color: var(--yellow);
  letter-spacing: 3px;
  line-height: 1;
  text-shadow: 4px 4px 0 var(--brown), 0 0 40px rgba(255,212,0,0.3);
}

.header-title span { color: var(--orange); }

.header-sub {
  font-size: 13px;
  color: var(--cream);
  opacity: 0.6;
  letter-spacing: 1px;
  margin-top: 4px;
}

/* ─── GAME AREA ─── */
#game-shell {
  width: min(520px, 98vw);
  margin-top: 20px;
}

/* Score bar */
#scorebar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--brown);
  border: 3px solid var(--orange);
  border-bottom: none;
  padding: 8px 16px;
}

.sb-item { text-align: center; }
.sb-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--orange);
  text-transform: uppercase;
}
.sb-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px;
  color: var(--yellow);
  line-height: 1;
}

/* Canvas */
#gameCanvas {
  display: block;
  width: 100%;
  border: 3px solid var(--orange);
  border-top: none;
  image-rendering: pixelated;
}

/* ─── INFO PANEL ─── */
#info-panel {
  width: min(520px, 98vw);
  margin-top: 0;
}

/* Lesson card */
.lesson-card {
  background: var(--brown);
  border: 3px solid var(--orange);
  border-top: none;
  padding: 0;
  overflow: hidden;
  transition: all 0.4s ease;
}

.lesson-header {
  background: var(--orange);
  padding: 8px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.lesson-icon { font-size: 22px; }

.lesson-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  color: var(--dark);
  letter-spacing: 2px;
}

.lesson-body {
  padding: 14px 18px;
  font-size: 14px;
  line-height: 1.7;
  color: var(--cream);
  min-height: 70px;
}

.lesson-body strong { color: var(--yellow); }
.lesson-body em { color: var(--orange); font-style: normal; }

/* Knowledge pills */
#knowledge-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 12px 16px;
  border-top: 2px solid rgba(255,107,26,0.3);
}

.kpill {
  padding: 4px 10px;
  border-radius: 2px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  opacity: 0.3;
  transition: all 0.4s;
  border: 1px solid currentColor;
}
.kpill.unlocked {
  opacity: 1;
  box-shadow: 0 0 8px currentColor;
  animation: pillPop 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes pillPop {
  from { transform: scale(0.5); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}

/* How to play */
#howto {
  background: rgba(255,107,26,0.08);
  border: 2px solid rgba(255,107,26,0.25);
  margin-top: 10px;
  padding: 12px 16px;
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  justify-content: center;
}
.ctrl {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--cream);
  opacity: 0.7;
}
.key {
  background: var(--brown);
  border: 1px solid var(--orange);
  color: var(--orange);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px;
  font-weight: 700;
  padding: 2px 8px;
  letter-spacing: 1px;
}

/* Mobile controls */
#mcontrols {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 10px;
}
.mcbtn {
  background: var(--brown);
  border: 2px solid var(--orange);
  color: var(--yellow);
  font-size: 20px;
  padding: 14px 22px;
  cursor: pointer;
  font-family: 'Bebas Neue', sans-serif;
  letter-spacing: 1px;
  font-size: 14px;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  transition: background 0.1s;
}
.mcbtn:active { background: var(--orange); color: var(--dark); }
.mcbtn.jump { background: var(--orange); color: var(--dark); flex: 1; }
.mcbtn.jump:active { background: var(--yellow); }

/* Overlay */
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(26,18,8,0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 20;
}
.overlay.hidden { display: none; }

.ov-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 48px;
  color: var(--yellow);
  text-shadow: 3px 3px 0 var(--brown);
  letter-spacing: 3px;
  text-align: center;
  line-height: 1;
}
.ov-sub {
  font-size: 13px;
  color: var(--cream);
  opacity: 0.6;
  margin: 8px 0 24px;
  text-align: center;
  max-width: 280px;
  line-height: 1.6;
}
.ov-btn {
  background: var(--orange);
  border: none;
  color: var(--dark);
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px;
  letter-spacing: 3px;
  padding: 12px 36px;
  cursor: pointer;
  transition: all 0.15s;
}
.ov-btn:hover { background: var(--yellow); transform: scale(1.04); }

.final-row {
  margin: 6px 0;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px;
  letter-spacing: 2px;
  color: var(--cream);
}
.final-row span { color: var(--yellow); font-size: 22px; }

/* canvas wrapper for overlay */
#canvas-wrap {
  position: relative;
  width: min(520px, 98vw);
  line-height: 0;
}
</style>
</head>
<body>

<header>
  <div class="header-tag">Juego Educativo</div>
  <div class="header-title">FACTORY <span>RUN</span></div>
  <div class="header-sub">Descubre por qué la Producción mueve a la empresa</div>
</header>

<div id="game-shell">
  <div id="scorebar">
    <div class="sb-item"><div class="sb-label">Piezas</div><div class="sb-val" id="sc-score">0</div></div>
    <div class="sb-item"><div class="sb-label">Lección</div><div class="sb-val" id="sc-level">1/6</div></div>
    <div class="sb-item"><div class="sb-label">Vidas</div><div class="sb-val" id="sc-lives">❤❤❤</div></div>
    <div class="sb-item"><div class="sb-label">Récord</div><div class="sb-val" id="sc-hi">0</div></div>
  </div>

  <div id="canvas-wrap">
    <canvas id="gameCanvas" width="520" height="260"></canvas>

    <div class="overlay" id="ovStart">
      <div class="ov-title">FACTORY RUN</div>
      <div class="ov-sub">Recoge piezas, esquiva fallas y aprende <strong>por qué el área de Producción es el corazón de toda empresa.</strong></div>
      <button class="ov-btn" id="btnStart">▶ INICIAR</button>
    </div>

    <div class="overlay hidden" id="ovLesson">
      <div style="text-align:center; padding: 0 20px;">
        <div style="font-family:'Bebas Neue';font-size:14px;letter-spacing:4px;color:var(--orange);margin-bottom:6px">LECCIÓN DESBLOQUEADA</div>
        <div class="ov-title" style="font-size:36px" id="ol-title">—</div>
        <div style="font-size:14px;color:var(--cream);line-height:1.7;margin:14px 0 22px;max-width:320px" id="ol-body">—</div>
        <button class="ov-btn" id="btnNext">SIGUIENTE RONDA ▶</button>
      </div>
    </div>

    <div class="overlay hidden" id="ovOver">
      <div class="ov-title" style="color:var(--orange)">LÍNEA PARADA</div>
      <div class="ov-sub">La producción nunca puede detenerse para siempre…</div>
      <div class="final-row">Piezas recolectadas: <span id="ov-score">0</span></div>
      <div class="final-row">Lecciones aprendidas: <span id="ov-lessons">0</span> / 6</div>
      <button class="ov-btn" style="margin-top:18px" id="btnRestart">↺ REINICIAR</button>
    </div>

    <div class="overlay hidden" id="ovWin">
      <div style="font-size:32px;margin-bottom:4px">🏭</div>
      <div class="ov-title" style="color:var(--green)">FÁBRICA MAESTRA</div>
      <div class="ov-sub">¡Completaste todas las lecciones! Ahora sabes por qué <strong>Producción</strong> es vital para cualquier empresa.</div>
      <div class="final-row">Puntuación total: <span id="ov-win-score">0</span></div>
      <button class="ov-btn" style="margin-top:18px;background:var(--green)" id="btnWinRestart">↺ JUGAR DE NUEVO</button>
    </div>
  </div>
</div>

<!-- INFO PANEL -->
<div id="info-panel">
  <div class="lesson-card">
    <div class="lesson-header">
      <span class="lesson-icon" id="l-icon">⚙️</span>
      <div class="lesson-title" id="l-title">RECOLECTA PIEZAS PARA APRENDER</div>
    </div>
    <div class="lesson-body" id="l-body">
      Corre por la fábrica, <strong>recoge piezas ⚙️</strong> para ganar puntos y lecciones, y <em>esquiva los defectos ❌</em> para no perder vidas. ¡Cada 15 piezas desbloqueas una nueva verdad sobre Producción!
    </div>
    <div id="knowledge-bar">
      <span class="kpill" style="color:#FFD400" id="kp0">⚙ Transformación</span>
      <span class="kpill" style="color:#FF6B1A" id="kp1">💰 Rentabilidad</span>
      <span class="kpill" style="color:#3DBA5C" id="kp2">✅ Calidad</span>
      <span class="kpill" style="color:#2F80ED" id="kp3">🔗 Cadena de valor</span>
      <span class="kpill" style="color:#BF5FFF" id="kp4">👥 Empleo</span>
      <span class="kpill" style="color:#E03030" id="kp5">🚀 Innovación</span>
    </div>
  </div>

  <div id="howto">
    <div class="ctrl"><span class="key">←→</span> Mover</div>
    <div class="ctrl"><span class="key">↑ / SPACE</span> Saltar</div>
    <div class="ctrl"><span class="key">P</span> Pausa</div>
    <div class="ctrl">⚙️ Recoger · ❌ Esquivar</div>
  </div>

  <div id="mcontrols">
    <button class="mcbtn" id="mc-left">◀ IZQ</button>
    <button class="mcbtn jump" id="mc-jump">▲ SALTAR</button>
    <button class="mcbtn" id="mc-right">DER ▶</button>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
// LESSONS
// ═══════════════════════════════════════════════════════
const LESSONS = [
  {
    icon: '⚙️',
    title: 'TRANSFORMACIÓN DE VALOR',
    body: `El área de <strong>Producción convierte materias primas en productos terminados</strong>. Sin este proceso, la empresa no tendría nada que ofrecer al mercado. Es el origen de todo valor económico que genera la organización.`,
    pill: 0, pillColor: '#FFD400'
  },
  {
    icon: '💰',
    title: 'MOTOR DE RENTABILIDAD',
    body: `Una producción <em>eficiente reduce costos</em> y maximiza el margen de ganancia. Cada proceso optimizado se traduce directamente en <strong>mayor utilidad para la empresa</strong>. La competitividad en precios depende de qué tan bien se produce.`,
    pill: 1, pillColor: '#FF6B1A'
  },
  {
    icon: '✅',
    title: 'GARANTÍA DE CALIDAD',
    body: `Producción establece los <strong>estándares de calidad</strong> del producto final. Un cliente satisfecho regresa; uno insatisfecho no vuelve. El control de calidad en planta es la primera y más importante línea de defensa de la reputación empresarial.`,
    pill: 2, pillColor: '#3DBA5C'
  },
  {
    icon: '🔗',
    title: 'ESLABÓN DE LA CADENA',
    body: `Producción conecta a <em>proveedores, logística, ventas y finanzas</em>. Si la línea se detiene, <strong>toda la cadena de valor se rompe</strong>. Por eso es considerada el área más crítica en empresas manufactureras y de servicios.`,
    pill: 3, pillColor: '#2F80ED'
  },
  {
    icon: '👥',
    title: 'GENERADOR DE EMPLEO',
    body: `El área productiva concentra el <strong>mayor número de colaboradores</strong> en la mayoría de empresas. Gestionar bien la producción significa gestionar bien al equipo humano: condiciones de trabajo, capacitación y <em>bienestar laboral</em>.`,
    pill: 4, pillColor: '#BF5FFF'
  },
  {
    icon: '🚀',
    title: 'FUENTE DE INNOVACIÓN',
    body: `Los procesos productivos generan <strong>conocimiento aplicado</strong>. Las mejoras en planta, la automatización y la investigación de métodos más eficientes son el terreno donde nace la <em>innovación real</em> que diferencia a las empresas líderes.`,
    pill: 5, pillColor: '#E03030'
  }
];

// ═══════════════════════════════════════════════════════
// GAME ENGINE
// ═══════════════════════════════════════════════════════
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const W = canvas.width, H = canvas.height;
const GROUND = H - 44;

// State
let gameState = 'start'; // start|playing|lesson|over|win|paused
let score = 0, hiScore = +localStorage.getItem('factory_hi')||0, lives = 3;
let lessonIdx = 0, lessonsUnlocked = 0;
let piecesSinceLesson = 0;
const PIECES_PER_LESSON = 15;

// Input
const keys = {};
const mob = { left:false, right:false, jump:false };

// Player
let player;
// Objects
let gears, defects, particles, bgElems;
let frameCount = 0;
let speed = 2.2;
let animId;
let paused = false;

// ─── COLORS ───────────────────────────────────────────
const C = {
  sky:    '#2A1C06',
  ground: '#3D2A08',
  belt:   '#5C3D12',
  stripe: '#FFD400',
  wall:   '#4A3510',
  girder: '#6B4F20',
};

function initGame() {
  score = 0; lives = 3; lessonIdx = 0; lessonsUnlocked = 0;
  piecesSinceLesson = 0; frameCount = 0; speed = 2.2;
  player = { x:80, y: GROUND - 36, w:28, h:36, vy:0, onGround:false, runFrame:0 };
  gears = []; defects = []; particles = [];
  bgElems = generateBG();
  updateHUD();
}

function generateBG() {
  const elems = [];
  // Pipes
  for (let i=0;i<6;i++) elems.push({type:'pipe', x: 80+i*90, y: 40+Math.random()*30});
  // Girders
  for (let i=0;i<4;i++) elems.push({type:'girder', x: 30+i*140, y: GROUND - 60});
  return elems;
}

// ─── MAIN LOOP ─────────────────────────────────────────
function loop() {
  if (gameState !== 'playing') return;
  frameCount++;
  update();
  draw();
  animId = requestAnimationFrame(loop);
}

function update() {
  // Speed ramp
  if (frameCount % 600 === 0) speed = Math.min(speed + 0.25, 5.5);

  // Player movement
  const left  = keys['ArrowLeft']  || keys['a'] || mob.left;
  const right  = keys['ArrowRight'] || keys['d'] || mob.right;
  const jump   = keys['ArrowUp'] || keys[' '] || keys['w'] || mob.jump;

  if (left)  player.x = Math.max(20, player.x - 3);
  if (right) player.x = Math.min(W - 60, player.x + 3);

  // Jump
  if (jump && player.onGround) {
    player.vy = -11;
    player.onGround = false;
    spawnDust(player.x + player.w/2, GROUND);
  }

  // Gravity
  player.vy += 0.55;
  player.y += player.vy;
  if (player.y >= GROUND - player.h) {
    player.y = GROUND - player.h;
    player.vy = 0;
    player.onGround = true;
  }

  // Run animation
  if (player.onGround && (left || right)) player.runFrame++;

  // Spawn gears
  if (frameCount % Math.max(28, 55 - lessonIdx*3) === 0) {
    const h = 18 + Math.random()*8;
    const flying = Math.random() < 0.25;
    gears.push({
      x: W + 30,
      y: flying ? GROUND - player.h - 50 - Math.random()*40 : GROUND - h,
      r: h/2,
      rot: 0,
      flying
    });
  }

  // Spawn defects
  if (frameCount % Math.max(50, 110 - lessonIdx*8) === 0) {
    const tall = Math.random() < 0.35;
    defects.push({
      x: W + 30,
      y: GROUND - (tall ? 52 : 22),
      w: 22, h: tall ? 52 : 22,
      type: tall ? 'tall' : 'low'
    });
  }

  // Move BG
  for (const e of bgElems) {
    e.x -= speed * 0.4;
    if (e.x < -100) e.x = W + 100;
  }

  // Move gears
  for (const g of gears) {
    g.x -= speed;
    g.rot += 0.06;
  }
  // Move defects
  for (const d of defects) d.x -= speed;

  // Particles
  for (const p of particles) { p.x+=p.vx; p.y+=p.vy; p.vy+=0.2; p.life--; }
  particles = particles.filter(p => p.life > 0);

  // Cleanup off-screen
  gears   = gears.filter(g => g.x > -60);
  defects = defects.filter(d => d.x > -60);

  // Collisions: collect gear
  for (const g of gears) {
    const dx = (player.x+player.w/2) - g.x;
    const dy = (player.y+player.h/2) - (g.y + g.r);
    if (Math.hypot(dx,dy) < g.r + 12) {
      g.x = -999;
      score += 10;
      piecesSinceLesson++;
      spawnCollect(g.x, g.y);
      updateHUD();
      if (piecesSinceLesson >= PIECES_PER_LESSON && lessonIdx < LESSONS.length) {
        showLesson();
      }
    }
  }

  // Collisions: hit defect
  for (const d of defects) {
    if (player.x + player.w - 4 > d.x &&
        player.x + 4 < d.x + d.w &&
        player.y + player.h > d.y &&
        player.y < d.y + d.h) {
      d.x = -999;
      hitPlayer();
    }
  }
}

function hitPlayer() {
  lives--;
  spawnExplode(player.x+player.w/2, player.y+player.h/2);
  updateHUD();
  if (lives <= 0) endGame();
}

function showLesson() {
  gameState = 'lesson';
  cancelAnimationFrame(animId);
  const l = LESSONS[lessonIdx];
  document.getElementById('ol-title').textContent = l.title;
  document.getElementById('ol-body').innerHTML = l.body;
  document.getElementById('ovLesson').classList.remove('hidden');
  // unlock pill
  document.getElementById('kp'+l.pill).classList.add('unlocked');
  // update card
  document.getElementById('l-icon').textContent = l.icon;
  document.getElementById('l-title').textContent = l.title;
  document.getElementById('l-body').innerHTML = l.body;
  lessonsUnlocked++;
  lessonIdx++;
  piecesSinceLesson = 0;
}

function endGame() {
  gameState = 'over';
  cancelAnimationFrame(animId);
  if (score > hiScore) { hiScore = score; localStorage.setItem('factory_hi', hiScore); }
  document.getElementById('ov-score').textContent = score;
  document.getElementById('ov-lessons').textContent = lessonsUnlocked;
  document.getElementById('ovOver').classList.remove('hidden');
}

function winGame() {
  gameState = 'win';
  cancelAnimationFrame(animId);
  if (score > hiScore) { hiScore = score; localStorage.setItem('factory_hi', hiScore); }
  document.getElementById('ov-win-score').textContent = score;
  document.getElementById('ovWin').classList.remove('hidden');
}

// ─── DRAW ──────────────────────────────────────────────
function draw() {
  ctx.clearRect(0,0,W,H);

  // Sky
  const skyGrad = ctx.createLinearGradient(0,0,0,H);
  skyGrad.addColorStop(0, '#150E03');
  skyGrad.addColorStop(1, '#2A1C06');
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0,0,W,H);

  // BG smoke / steam
  drawBGElems();

  // Conveyor belt
  drawBelt();

  // Gears (collectibles)
  for (const g of gears) drawGear(g);

  // Defects
  for (const d of defects) drawDefect(d);

  // Player
  drawPlayer();

  // Particles
  for (const p of particles) {
    ctx.globalAlpha = p.life/p.maxLife;
    ctx.fillStyle = p.color;
    ctx.fillRect(p.x-p.r, p.y-p.r, p.r*2, p.r*2);
  }
  ctx.globalAlpha = 1;

  // Foreground floor
  ctx.fillStyle = C.ground;
  ctx.fillRect(0, GROUND, W, H-GROUND);
  // floor line
  ctx.fillStyle = '#FFD40020';
  ctx.fillRect(0, GROUND, W, 3);
}

function drawBGElems() {
  const t = frameCount;
  for (const e of bgElems) {
    if (e.type === 'pipe') {
      ctx.fillStyle = '#5C3D12';
      ctx.fillRect(e.x, e.y, 14, H - e.y - 44);
      // steam puff
      const puff = Math.sin(t*0.04 + e.x)*6;
      ctx.globalAlpha = 0.18 + Math.sin(t*0.04)*0.08;
      ctx.fillStyle = '#FFF5E0';
      ctx.beginPath();
      ctx.arc(e.x+7, e.y - 10 + puff, 12, 0, Math.PI*2);
      ctx.fill();
      ctx.globalAlpha = 1;
    }
    if (e.type === 'girder') {
      ctx.fillStyle = '#6B4F20';
      ctx.fillRect(e.x, e.y, 120, 8);
      // bolts
      ctx.fillStyle = '#3D2A08';
      for (let i=0;i<4;i++) ctx.fillRect(e.x+8+i*30, e.y+2, 4,4);
    }
  }
}

function drawBelt() {
  // Belt base
  ctx.fillStyle = '#5C3D12';
  ctx.fillRect(0, GROUND - 8, W, 8);

  // Moving stripes
  const offset = (frameCount * speed) % 40;
  ctx.fillStyle = '#FFD400';
  for (let x = -40 + offset; x < W + 40; x += 40) {
    ctx.fillRect(x, GROUND - 7, 14, 6);
  }

  // Belt edge
  ctx.fillStyle = '#3D2A08';
  ctx.fillRect(0, GROUND - 10, W, 3);
  ctx.fillRect(0, GROUND, W, 3);
}

function drawGear(g) {
  ctx.save();
  ctx.translate(g.x, g.y + g.r);
  ctx.rotate(g.rot);
  const teeth = 8;
  ctx.fillStyle = g.flying ? '#FFD400' : '#FF6B1A';
  ctx.shadowColor = g.flying ? '#FFD400' : '#FF6B1A';
  ctx.shadowBlur = 8;
  for (let i=0;i<teeth;i++) {
    const angle = (i/teeth)*Math.PI*2;
    ctx.save();
    ctx.rotate(angle);
    ctx.fillRect(-3, -g.r - 5, 6, 6);
    ctx.restore();
  }
  ctx.beginPath();
  ctx.arc(0,0,g.r*0.85,0,Math.PI*2);
  ctx.fill();
  ctx.fillStyle = C.ground;
  ctx.beginPath();
  ctx.arc(0,0,g.r*0.35,0,Math.PI*2);
  ctx.fill();
  ctx.restore();
}

function drawDefect(d) {
  ctx.fillStyle = '#E03030';
  ctx.shadowColor = '#E03030';
  ctx.shadowBlur = 6;
  ctx.fillRect(d.x, d.y, d.w, d.h);
  // X mark
  ctx.fillStyle = '#fff';
  ctx.shadowBlur = 0;
  ctx.font = `bold ${d.type==='tall'?22:14}px Bebas Neue`;
  ctx.textAlign = 'center';
  ctx.fillText('✕', d.x+d.w/2, d.y+d.h/2 + (d.type==='tall'?8:5));
  ctx.shadowBlur = 0;
}

function drawPlayer() {
  const x = player.x, y = player.y;
  const run = Math.floor(player.runFrame/6)%2;

  // Body (worker jumpsuit)
  ctx.fillStyle = '#2F80ED';
  ctx.fillRect(x+4, y+10, 20, 22);
  // Helmet
  ctx.fillStyle = '#FFD400';
  ctx.fillRect(x+2, y, 24, 12);
  // Face
  ctx.fillStyle = '#D4956A';
  ctx.fillRect(x+6, y+4, 16, 10);
  // Eyes
  ctx.fillStyle = '#1A1208';
  ctx.fillRect(x+8, y+6, 3, 3);
  ctx.fillRect(x+17, y+6, 3, 3);
  // Arms
  ctx.fillStyle = '#2F80ED';
  ctx.fillRect(x-2, y+10, 6, 16);
  ctx.fillRect(x+24, y+10, 6, 16);
  // Legs (animated)
  ctx.fillStyle = '#1A5FAD';
  if (run === 0) {
    ctx.fillRect(x+5, y+30, 8, 14);
    ctx.fillRect(x+15, y+33, 8, 11);
  } else {
    ctx.fillRect(x+5, y+33, 8, 11);
    ctx.fillRect(x+15, y+30, 8, 14);
  }
  // Wrench tool
  ctx.fillStyle = '#8FA3B1';
  ctx.fillRect(x+24, y+12, 4, 10);
  ctx.fillRect(x+22, y+10, 8, 4);
}

// ─── PARTICLES ─────────────────────────────────────────
function spawnCollect(x,y) {
  const colors = ['#FFD400','#FF6B1A','#fff'];
  for (let i=0;i<8;i++) {
    const angle = Math.random()*Math.PI*2;
    const spd = Math.random()*4+1;
    particles.push({ x, y,
      vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd - 2,
      r: Math.random()*3+1,
      color: colors[Math.floor(Math.random()*colors.length)],
      life: 20, maxLife: 20
    });
  }
}

function spawnDust(x,y) {
  for (let i=0;i<5;i++) {
    particles.push({ x, y,
      vx: (Math.random()-0.5)*3, vy: -Math.random()*1.5,
      r: 2, color: '#5C3D12', life: 12, maxLife: 12
    });
  }
}

function spawnExplode(x,y) {
  for (let i=0;i<14;i++) {
    const angle = Math.random()*Math.PI*2;
    const spd = Math.random()*5+2;
    particles.push({ x, y,
      vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd - 2,
      r: Math.random()*4+1, color:'#E03030',
      life: 25, maxLife: 25
    });
  }
}

// ─── HUD ───────────────────────────────────────────────
function updateHUD() {
  document.getElementById('sc-score').textContent = score;
  document.getElementById('sc-level').textContent = (lessonIdx+1)+'/6';
  document.getElementById('sc-lives').textContent = '❤'.repeat(Math.max(0,lives));
  document.getElementById('sc-hi').textContent = Math.max(hiScore,score);
}

// ─── INPUT ─────────────────────────────────────────────
document.addEventListener('keydown', e => {
  keys[e.key] = true;
  if (e.key === ' ') e.preventDefault();
  if ((e.key === 'p'||e.key==='P') && gameState==='playing') togglePause();
});
document.addEventListener('keyup', e => { keys[e.key]=false; });

function hold(id, prop) {
  const el = document.getElementById(id);
  el.addEventListener('pointerdown', e => { e.preventDefault(); mob[prop]=true; });
  el.addEventListener('pointerup',   () => mob[prop]=false);
  el.addEventListener('pointerleave',() => mob[prop]=false);
}
hold('mc-left','left'); hold('mc-right','right'); hold('mc-jump','jump');

function togglePause() {
  if (gameState==='playing') {
    paused = true; gameState='paused';
    cancelAnimationFrame(animId);
    ctx.fillStyle='rgba(26,18,8,0.75)';
    ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#FFD400';
    ctx.font='bold 32px Bebas Neue';
    ctx.textAlign='center';
    ctx.fillText('PAUSA',W/2,H/2);
    ctx.fillStyle='rgba(255,245,224,0.4)';
    ctx.font='14px Barlow';
    ctx.fillText('Presiona P para continuar',W/2,H/2+28);
  } else if (gameState==='paused') {
    gameState='playing';
    loop();
  }
}

// ─── BUTTONS ───────────────────────────────────────────
document.getElementById('btnStart').addEventListener('click', () => {
  document.getElementById('ovStart').classList.add('hidden');
  initGame();
  updateHUD();
  gameState='playing';
  loop();
});

document.getElementById('btnNext').addEventListener('click', () => {
  document.getElementById('ovLesson').classList.add('hidden');
  if (lessonIdx >= LESSONS.length) {
    winGame(); return;
  }
  gameState='playing';
  loop();
});

document.getElementById('btnRestart').addEventListener('click', () => {
  document.getElementById('ovOver').classList.add('hidden');
  // reset pills
  for (let i=0;i<6;i++) document.getElementById('kp'+i).classList.remove('unlocked');
  initGame(); updateHUD();
  gameState='playing';
  loop();
});

document.getElementById('btnWinRestart').addEventListener('click', () => {
  document.getElementById('ovWin').classList.add('hidden');
  for (let i=0;i<6;i++) document.getElementById('kp'+i).classList.remove('unlocked');
  initGame(); updateHUD();
  gameState='playing';
  loop();
});

// Init HUD
updateHUD();
</script>
